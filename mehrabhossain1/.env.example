# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- Database (Neon Postgres) ---
# Pooled connection string — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full&pgbouncer=true"
# Direct (unpooled) connection string — used by Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full"

# --- Auth.js ---
# Random secret. Generate with: openssl rand -base64 33
AUTH_SECRET="generate-me"
# App URL — http://localhost:3000 in dev; the Vercel domain in production.
AUTH_URL="http://localhost:3000"
